<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background_rounded"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recovery Key"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Save this key in a safe place. You will need it if you forget your password."
        android:textColor="#B0B0B0"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvRecoveryKeyDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#1E1E1E"
        android:gravity="center"
        android:padding="16dp"
        android:text="A1B2C3D4E5F6G7H8"
        android:textColor="#03DAC5"
        android:textSize="18sp"
        android:typeface="monospace"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCopyAgain"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COPY AGAIN"
            android:textColor="#03DAC5" />

        <Button
            android:id="@+id/btnDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:backgroundTint="#03DAC5"
            android:paddingHorizontal="24dp"
            android:text="I'VE SAVED IT"
            android:textColor="#121212" />
    </LinearLayout>
</LinearLayout>